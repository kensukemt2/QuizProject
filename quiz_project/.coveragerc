# カバレッジ測定の設定ファイル

[run]
source = quiz_api
omit =
    */migrations/*
    */tests.py
    */test_*.py
    */__init__.py
    */venv/*
    */env/*

[report]
# 除外するファイル
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if settings.DEBUG
    pass

# レポートの精度
precision = 2

# カバレッジが低いファイルをハイライト
show_missing = True

[html]
directory = htmlcov
