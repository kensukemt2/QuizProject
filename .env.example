# 環境変数テンプレート - マジカルクイズ
# このファイルをコピーして .env を作成し、適切な値を設定してください

# ===========================================
# 基本設定
# ===========================================

# 環境 (development, staging, production)
ENVIRONMENT=development

# デバッグモード (True/False)
DEBUG=True

# シークレットキー (本番環境では必ず変更!)
SECRET_KEY=django-insecure-change-this-in-production

# 許可するホスト (カンマ区切り)
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================================
# データベース設定
# ===========================================

# SQLite (開発環境)
# DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (本番環境)
# DATABASE_URL=postgresql://user:password@localhost:5432/quiz_db
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ===========================================
# CORS設定
# ===========================================

# CORS許可オリジン (カンマ区切り)
CORS_ALLOWED_ORIGINS=http://localhost:8082,http://localhost:8081

# すべてのオリジンを許可 (開発環境のみ)
CORS_ALLOW_ALL_ORIGINS=True

# ===========================================
# JWT設定
# ===========================================

# JWTトークンの有効期限 (分)
JWT_ACCESS_TOKEN_LIFETIME=1440

# JWTリフレッシュトークンの有効期限 (日)
JWT_REFRESH_TOKEN_LIFETIME=7

# ===========================================
# メール設定
# ===========================================

# メールバックエンド
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTPサーバー設定 (本番環境)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-password
# DEFAULT_FROM_EMAIL=noreply@magicalquiz.example.com

# ===========================================
# 静的ファイル・メディアファイル設定
# ===========================================

# 静的ファイルURL
STATIC_URL=/static/

# メディアファイルURL
MEDIA_URL=/media/

# メディアファイルの保存先
MEDIA_ROOT=media

# ===========================================
# AWS S3設定 (本番環境でS3を使用する場合)
# ===========================================

# USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=ap-northeast-1
# AWS_S3_CUSTOM_DOMAIN=
# AWS_S3_FILE_OVERWRITE=False

# ===========================================
# レートリミット設定
# ===========================================

# 匿名ユーザーのリクエスト制限 (リクエスト数/分)
ANON_THROTTLE_RATE=30/minute

# 認証済みユーザーのリクエスト制限 (リクエスト数/分)
USER_THROTTLE_RATE=120/minute

# 認証エンドポイントのリクエスト制限 (リクエスト数/分)
AUTH_THROTTLE_RATE=5/minute

# ===========================================
# アップロード設定
# ===========================================

# 最大アップロードサイズ (バイト, デフォルト: 5MB)
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880

# ===========================================
# ロギング設定
# ===========================================

# ログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ログファイルパス
LOG_FILE_PATH=logs/django.log

# ===========================================
# セキュリティ設定 (本番環境)
# ===========================================

# HTTPS強制リダイレクト
# SECURE_SSL_REDIRECT=True

# セキュアクッキー
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# HSTS設定
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# ===========================================
# サードパーティAPI設定
# ===========================================

# Stripe (決済)
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Google Analytics
# GA_TRACKING_ID=

# Sentry (エラー監視)
# SENTRY_DSN=

# ===========================================
# フロントエンド設定
# ===========================================

# フロントエンドURL
FRONTEND_URL=http://localhost:8082

# API URL
API_BASE_URL=http://localhost:8000/api

# ===========================================
# Redis設定 (キャッシュ・セッション)
# ===========================================

# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# ===========================================
# Celery設定 (非同期タスク)
# ===========================================

# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
